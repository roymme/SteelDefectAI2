# LLM (used via langchain init_chat_model, format "provider:model")
GROQ_API_KEY=your_groq_key_here
LLM_MODEL=groq:llama-3.3-70b-versatile

# Internet search tool (leave unset to disable the tool gracefully)
TAVILY_API_KEY=your_tavily_key_here

# Your Kaggle-trained ResNet50 defect classifier, exposed as an HTTP
# endpoint that accepts a multipart "file" and returns
# {"predicted_class": "...", "confidence": 0.93}
# Leave unset to fall back to the built-in POC mock classifier.
KAGGLE_INFERENCE_URL=

# Where ingest_book.py saves / app.py loads the FAISS index of your
# Ironmaking & Steelmaking textbook.
BOOK_INDEX_DIR=book_index
